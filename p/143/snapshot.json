{"format":"velxio-project","version":1,"boards":[{"id":"arduino-uno","boardKind":"arduino-uno","x":-244.6061871532666,"y":73.42105412758409,"activeFileGroupId":"group-arduino-uno","languageMode":"arduino","serialBaudRate":0}],"fileGroups":{"group-arduino-uno":[{"name":"sketch.ino","content":"const int LED_PIN = 3;      // PWM pin (~) for brightness\nconst int BUTTON_PIN = 2;   // button to GND, uses internal pull-up\nconst int POT_PIN = A0;     // potentiometer wiper\n\nbool ledOn = false;             // current on/off state\nint lastButtonReading = HIGH;   // last raw reading (HIGH = not pressed with pull-up)\nunsigned long lastDebounceTime = 0;\nconst unsigned long debounceDelay = 50;\n\nvoid setup() {\n  pinMode(LED_PIN, OUTPUT);\n  pinMode(BUTTON_PIN, INPUT_PULLUP);  // no external resistor needed\n}\n\nvoid loop() {\n  // --- Read button with debounce ---\n  int reading = digitalRead(BUTTON_PIN);\n\n  if (reading != lastButtonReading) {\n    lastDebounceTime = millis();   // input changed, reset timer\n  }\n\n  if ((millis() - lastDebounceTime) > debounceDelay) {\n    // reading has been stable long enough\n    static int buttonState = HIGH;\n    if (reading != buttonState) {\n      buttonState = reading;\n      // with INPUT_PULLUP, a press pulls the pin LOW\n      if (buttonState == LOW) {\n        ledOn = !ledOn;   // toggle on each press\n      }\n    }\n  }\n  lastButtonReading = reading;\n\n  // --- Set brightness from potentiometer ---\n  if (ledOn) {\n    int potValue = analogRead(POT_PIN);          // 0..1023\n    int brightness = map(potValue, 0, 1023, 0, 255);\n    analogWrite(LED_PIN, brightness);\n  } else {\n    analogWrite(LED_PIN, 0);                      // off\n  }\n}"}]},"components":[{"id":"breadboard_full_1783968605893_06743uapw","metadataId":"breadboard-full","x":8.453661301670707,"y":66.38193107440469,"properties":{"state":true,"value":true}},{"id":"led_blue_1783971094932_vc6ncqa6x","metadataId":"led-blue","x":66.85366130167071,"y":151.3819310744047,"properties":{"color":"blue","rotation":180},"attachedTo":{"breadboardId":"breadboard_full_1783968605893_06743uapw","pinMap":{"A":"F10","C":"F11"}}},{"id":"resistor_220_1783971184624_y6xuxwajl","metadataId":"resistor-220","x":51.45366130167071,"y":185.73193107440468,"properties":{"value":"220"},"attachedTo":{"breadboardId":"breadboard_full_1783968605893_06743uapw","pinMap":{"1":"F3","2":"F9"}}},{"id":"potentiometer_1783971361138_m55iyz1fd","metadataId":"potentiometer","x":205.65366130167067,"y":122.88193107440469,"properties":{"min":0,"max":1023,"value":534,"step":1,"startDegree":-135,"endDegree":135},"attachedTo":{"breadboardId":"breadboard_full_1783968605893_06743uapw","pinMap":{"GND":"F22","SIG":"F23","VCC":"F24"}}},{"id":"pushbutton_1783973192202_kx2roclbl","metadataId":"pushbutton","x":398.4536613016708,"y":159.3819310744047,"properties":{"color":"red","pressed":false,"label":"","xray":false},"attachedTo":{"breadboardId":"breadboard_full_1783968605893_06743uapw","pinMap":{"2.l":"F39","2.r":"F46"}}}],"wires":[{"waypoints":[],"id":"wire-1783971438866","start":{"componentId":"breadboard_full_1783968605893_06743uapw","pinName":"F10","x":125.8536613016707,"y":197.3819310744047},"end":{"componentId":"resistor_220_1783971184624_y6xuxwajl","pinName":"2","x":116.2536613016707,"y":197.3819310744047},"color":"#22c55e"},{"waypoints":[],"id":"wire-1783973204321","start":{"componentId":"pushbutton_1783973192202_kx2roclbl","pinName":"1.r","x":471.4536613016708,"y":178.3819310744047},"end":{"componentId":"breadboard_full_1783968605893_06743uapw","pinName":"E46","x":471.4536613016707,"y":164.3819310744047},"color":"#22c55e"},{"waypoints":[],"id":"wire-1783973206364","start":{"componentId":"pushbutton_1783973192202_kx2roclbl","pinName":"1.l","x":404.4536613016708,"y":178.3819310744047},"end":{"componentId":"breadboard_full_1783968605893_06743uapw","pinName":"E39","x":404.2536613016707,"y":164.3819310744047},"color":"#22c55e"},{"waypoints":[],"id":"wire-1783973320107"