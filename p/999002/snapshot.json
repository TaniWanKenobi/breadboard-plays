:1002700004018091050190910601A0910701B091C0\n:1002800008010196A11DB11D8093050190930601FF\n:10029000A0930701B0930801BF91AF919F918F91F7\n:1002A0003F912F910F900FBE0F901F90189526E849\n:1002B000230F0296A11DB11DD2CF789484B5826020\n:1002C00084BD84B5816084BD85B5826085BD85B5FA\n:1002D000816085BD80916E00816080936E00109278\n:1002E00081008091810082608093810080918100F3\n:1002F0008160809381008091800081608093800084\n:100300008091B10084608093B1008091B0008160E1\n:100310008093B00080917A00846080937A0080910D\n:100320007A00826080937A0080917A008160809365\n:100330007A0080917A00806880937A001092C100E0\n:10034000EDE9F0E02491E9E8F0E08491882399F068\n:1003500090E0880F991FFC01E859FF4FA591B491D7\n:10036000FC01EE58FF4F859194918FB7F894EC9172\n:10037000E22BEC938FBFC0E0D0E081E00E947000E0\n:100380000E94DD0080E00E9470000E94DD00209746\n:0C039000A1F30E940000F1CFF894FFCF11\n:00000001FF\n"}],"fileGroups":{"group-arduino-uno":[{"name":"sketch.ino","content":"const int LED_PIN = 3;      // PWM pin (~) for brightness\r\nconst int BUTTON_PIN = 2;   // button to GND, uses internal pull-up\r\nconst int POT_PIN = A0;     // potentiometer wiper\r\n\r\nbool ledOn = false;             // current on/off state\r\nint lastButtonReading = HIGH;   // last raw reading (HIGH = not pressed with pull-up)\r\nunsigned long lastDebounceTime = 0;\r\nconst unsigned long debounceDelay = 50;\r\n\r\nvoid setup() {\r\n  pinMode(LED_PIN, OUTPUT);\r\n  pinMode(BUTTON_PIN, INPUT_PULLUP);  // no external resistor needed\r\n}\r\n\r\nvoid loop() {\r\n  // --- Read button with debounce ---\r\n  int reading = digitalRead(BUTTON_PIN);\r\n\r\n  if (reading != lastButtonReading) {\r\n    lastDebounceTime = millis();   // input changed, reset timer\r\n  }\r\n\r\n  if ((millis() - lastDebounceTime) > debounceDelay) {\r\n    // reading has been stable long enough\r\n    static int buttonState = HIGH;\r\n    if (reading != buttonState) {\r\n      buttonState = reading;\r\n      // with INPUT_PULLUP, a press pulls the pin LOW\r\n      if (buttonState == LOW) {\r\n        ledOn = !ledOn;   // toggle on each press\r\n      }\r\n    }\r\n  }\r\n  lastButtonReading = reading;\r\n\r\n  // --- Set brightness from potentiometer ---\r\n  if (ledOn) {\r\n    int potValue = analogRead(POT_PIN);          // 0..1023\r\n    int brightness = map(potValue, 0, 1023, 0, 255);\r\n    analogWrite(LED_PIN, brightness);\r\n  } else {\r\n    analogWrite(LED_PIN, 0);                      // off\r\n  }\r\n}\r\n"}]},"components":[{"id":"potentiometer_1783389993562_7b1zhbech","metadataId":"potentiometer","x":-87.40196268961841,"y":-161.66844988708698,"properties":{"min":0,"max":1023,"value":27,"step":1,"startDegree":-135,"endDegree":135},"attachedTo":{"breadboardId":"breadboard_full_1783488484183_ce90rnhn0","pinMap":{"GND":"F17","SIG":"F18","VCC":"F19"}}},{"id":"led_red_1783489850661_o1324gkt4","metadataId":"led-red","x":-175.20196268961843,"y":-133.16844988708698,"properties":{"color":"red","rotation":180},"attachedTo":{"breadboardId":"breadboard_full_1783488484183_ce90rnhn0","pinMap":{"A":"F10","C":"F11"}}},{"id":"resistor_220_1783490018403_qo3x1qc0j","metadataId":"resistor-220","x":-265.4019626896184,"y":-124.51844988708696,"properties":{"value":"220","rotation":180},"attachedTo":{"breadboardId":"breadboard_full_1783488484183_ce90rnhn0","pinMap":{"1":"F8","2":"F2"}}},{"id":"breadboard_full_1783488484183_ce90rnhn0","metadataId":"breadboard-full","x":-236.6019626896184,"y":-218.16844988708698,"properties":{"state":false,"value":false}},{"id":"pushbutton_1783498655239_u6urmk9tb","metadataId":"pushbutton","x":50.398037310381596,"y":-157.16844988708698,"properties":{"color":"red","pressed":false,"label":"","xray":false,"rotation":180},"attachedTo":{"breadboardId":"breadboard_full_1783488484183_ce90rnhn0","pinMap":{"1.l":"F36","1.r":"F29"}}}],"wires":[{"waypoints":[],"id":"wire-1783490067909","start":{"componentId":"resistor_220_1783490018403_qo3x1qc0j","pinName":"1","x":-137.40196268961841,"y":-86.16844988708698},"end":{"componentId":"le